# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bagiberkah?schema=public"

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here

# Xendit Payment Gateway (THR System)
XENDIT_API_KEY=your-xendit-api-key
XENDIT_WEBHOOK_SECRET=your-xendit-webhook-secret
XENDIT_BASE_URL=https://api.xendit.co

# Mayar Payment Gateway (Support Developer)
# Get your API key from: https://mayar.id/dashboard/developer
MAYAR_API_KEY=your-mayar-api-key
MAYAR_WEBHOOK_SECRET=your-mayar-webhook-secret
MAYAR_BASE_URL=https://api.mayar.club/hl/v1

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# App Configuration
APP_NAME=BagiBerkah
APP_URL=http://localhost:5000
