// Prisma Schema for BagiBerkah

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum AgeLevel {
  CHILD
  TEEN
  ADULT
}

enum Status {
  SCHOOL
  COLLEGE
  WORKING
  NOT_WORKING
}

enum Closeness {
  VERY_CLOSE
  CLOSE
  DISTANT
}

enum DistributionMode {
  DIGITAL
  CASH
}

enum EnvelopeStatus {
  DRAFT
  PENDING_PAYMENT
  ACTIVE
  COMPLETED
  EXPIRED
}

enum ClaimStatus {
  PENDING
  OPENED
  CLAIMED
  VALIDATED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum PlayableType {
  DIRECT      // Langsung dapat
  GAME        // Harus main game
  QUIZ        // Harus jawab quiz
}

enum GameType {
  MEMORY_CARD     // Memory card matching game
  SPIN_WHEEL      // Spin the wheel
  SCRATCH_CARD    // Scratch card reveal
  BALLOON_POP     // Pop balloons
  TREASURE_HUNT   // Find hidden treasure
}

enum QuizDifficulty {
  EASY
  MEDIUM
  HARD
}

// Models
model Envelope {
  id               String           @id @default(cuid())
  envelopeName     String?          // Name/title for the envelope
  accessCode       String?          @unique // Code to access envelope status
  totalBudget      Int
  distributionMode DistributionMode
  status           EnvelopeStatus   @default(DRAFT)
  
  // Relations
  recipients       Recipient[]
  payment          Payment?
  
  // Timestamps
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  expiresAt        DateTime?
  
  @@index([status])
  @@index([createdAt])
  @@index([accessCode])
}

model Recipient {
  id               String      @id @default(cuid())
  name             String
  ageLevel         AgeLevel
  status           Status
  closeness        Closeness
  contact          String?
  greetingContext  String?
  
  // AI Allocation
  allocatedAmount  Int
  aiReasoning      String?
  aiGreeting       String?
  
  // Playable settings (per recipient)
  playableType     PlayableType     @default(DIRECT)
  gameType         GameType?        // If playableType = GAME
  quizTopic        String?          // If playableType = QUIZ
  quizDifficulty   QuizDifficulty?  // If playableType = QUIZ
  quizQuestions    Json?            // Generated quiz questions
  
  // Relations
  envelope         Envelope    @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  envelopeId       String
  claim            Claim?
  
  // Timestamps
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  
  @@index([envelopeId])
}

model Claim {
  id               String       @id @default(cuid())
  token            String       @unique
  qrToken          String?      @unique
  status           ClaimStatus  @default(PENDING)
  
  // Claim details
  claimMethod      String?      // 'digital' or 'cash'
  bankAccount      String?
  bankName         String?
  
  // Playable progress
  gameCompleted    Boolean      @default(false)
  gameScore        Int?
  gameAttempts     Int          @default(0)
  gameStartedAt    DateTime?
  gameCompletedAt  DateTime?
  
  // Relations
  recipient        Recipient    @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId      String       @unique
  
  // Timestamps
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  openedAt         DateTime?
  claimedAt        DateTime?
  validatedAt      DateTime?
  expiresAt        DateTime
  
  @@index([token])
  @@index([qrToken])
  @@index([status])
}

model Payment {
  id               String        @id @default(cuid())
  paymentId        String        @unique  // From payment gateway
  amount           Int
  status           PaymentStatus @default(PENDING)
  paymentUrl       String?
  
  // Payment gateway details
  gatewayResponse  Json?
  
  // Relations
  envelope         Envelope      @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  envelopeId       String        @unique
  
  // Timestamps
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  paidAt           DateTime?
  expiresAt        DateTime?
  
  @@index([paymentId])
  @@index([status])
}

model AuditLog {
  id               String        @id @default(cuid())
  action           String
  entityType       String
  entityId         String
  details          Json?
  ipAddress        String?
  userAgent        String?
  
  createdAt        DateTime      @default(now())
  
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Donation {
  id               String        @id @default(cuid())
  paymentId        String        @unique
  amount           Int
  donorName        String        @default("Anonymous")
  message          String?
  status           PaymentStatus @default(PENDING)
  paymentUrl       String?
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  paidAt           DateTime?
  
  @@index([status])
  @@index([createdAt])
}
